{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@types/*": [
                "src/types/*"
            ],
            "@models/*": [
                "src/models/*"
            ],
            "@utils/*": [
                "src/utils/*"
            ]
        },
        "checkJs": true,
        "strict": true,
        "target": "ES2022",
        "module": "ES2022",
        "moduleResolution": "node"
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}